---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import { Github, ExternalLink } from 'lucide-react';
import { Button } from '@/components/ui/button';
import { Card, CardHeader, CardTitle, CardDescription, CardContent } from '@/components/ui/card';
import { Badge } from '@/components/ui/badge';
import { Input } from '@/components/ui/input';
import { Textarea } from '@/components/ui/textarea';
import ThemeProvider from '@/components/ThemeProvider';

// Imágenes de placeholder para optimización
import profileImage from '@/assets/profile.jpg';
import magnoliasImage from '@/assets/project-magnolias.jpg';

const experience = [
  {
    role: "Desarrollador en Práctica (Full Stack & Data Analysis)",
    company: "Ripley Chile",
    period: "Sep 2025 – Dic 2025",
    description: "Diseñé un módulo de análisis con tablas dinámicas y gráficos interactivos, optimizando la visualización de métricas críticas. Implementé funciones de filtrado y ordenamiento avanzado para grandes volúmenes de información, mejorando la velocidad de interpretación y la UX. Colaboré en entornos ágiles bajo estándares corporativos."
  }
];

const education = [
  {
    degree: "Ingeniería en Informática",
    institution: "Instituto Profesional Duoc UC",
    period: "Mar 2022 - Dic 2025",
    description: "Enfoque en el desarrollo de soluciones Full Stack y optimización de procesos mediante el análisis de datos y la automatización con IA."
  },
  {
    degree: "Técnico Analista Programador Computacional",
    institution: "Instituto Profesional Duoc UC",
    period: "Mar 2022 - Jul 2024",
    description: "Formación técnica integral en análisis de sistemas, programación y bases de datos."
  }
];

const projects = [
  {
    title: "Sistema de Gestión 'Magnolias Asesorías'",
    description: "Proyecto de Título. Desarrollé una plataforma escalable optimizando arquitectura y rendimiento. Integré flujos inteligentes para automatizar asesorías y reducir la carga operativa. Diseñé bases de datos robustas y gestioné versiones.",
    tags: ["Arquitectura de Software", "Bases de Datos", "Automatización"],
    demoUrl: "https://frontend-magnolias.vercel.app/",
    repoUrl: "https://github.com/Capstone-Grupo3/Monorepo-Magnolias",
    image: magnoliasImage
  }
];

const skills = [
  "Python", "Java", "SQL", "HTML5", "CSS3", "JavaScript", "Angular", 
  "Google Cloud", "Firebase", "MySQL", "PostgreSQL", "Git", "React", 
  "TypeScript", "NodeJS"
];
---

<Layout title="Carlos González | Ingeniero en Informática">
  <!-- Navbar Glass -->
  <header class="sticky top-0 z-50 w-full border-b border-border/40 bg-background/60 backdrop-blur-xl supports-[backdrop-filter]:bg-background/40">
    <div class="container mx-auto max-w-5xl flex h-16 items-center justify-between px-4 lg:px-8">
      <div class="mr-4 flex">
        <a href="/" class="mr-6 flex items-center space-x-2 font-heading font-bold text-xl tracking-tight text-primary">
          CG<span class="text-foreground">.</span>
        </a>
        <nav class="hidden md:flex items-center space-x-8 text-sm font-medium text-muted-foreground">
          <a href="#perfil" class="transition-colors hover:text-primary">Perfil</a>
          <a href="#experiencia" class="transition-colors hover:text-primary">Experiencia</a>
          <a href="#educacion" class="transition-colors hover:text-primary">Educación</a>
          <a href="#proyectos" class="transition-colors hover:text-primary">Proyectos</a>
        </nav>
      </div>
      <div class="flex items-center justify-end space-x-4">
        <!-- Puedes añadir el botón de toggle de tema de Shadcn aquí usando el ThemeProvider -->
        <a href="/CV_CarlosGonzalez.pdf" target="_blank" class="hidden sm:inline-flex">
          <Button variant="outline" size="sm" class="glass-panel glass-panel-hover rounded-full px-6">
            Ver Currículum
          </Button>
        </a>
      </div>
    </div>
  </header>

  <main class="container mx-auto max-w-5xl px-4 lg:px-8 py-12 md:py-24 relative">
    
    <!-- Hero Section -->
    <section id="perfil" class="relative flex flex-col md:flex-row items-center gap-10 py-8 md:py-20 md:pb-28">
      <!-- Glow Orb tras el Hero -->
      <div class="absolute top-1/2 left-1/4 -translate-y-1/2 -translate-x-1/2 w-[300px] h-[300px] bg-primary/20 rounded-full blur-[100px] pointer-events-none -z-10"></div>
      
      <div class="flex-1 space-y-6">
        <div class="opacity-0 animate-fade-in-up">
          <Badge variant="secondary" class="px-4 py-1.5 rounded-full border border-primary/20 bg-primary/10 text-primary font-medium tracking-wide">
            Ingeniero en Informática
          </Badge>
        </div>
        
        <h1 class="text-4xl font-extrabold leading-tight tracking-tighter md:text-6xl lg:text-7xl lg:leading-[1.1] opacity-0 animate-fade-in-up animate-delay-100">
          Hola, soy <span class="text-gradient">Carlos González.</span> <br class="hidden sm:inline" />
          Desarrollador Full Stack & <br class="hidden sm:inline" /> Data Analysis.
        </h1>
        
        <p class="max-w-[700px] text-lg text-muted-foreground sm:text-xl font-light leading-relaxed opacity-0 animate-fade-in-up animate-delay-200">
          Enfoque en el desarrollo de soluciones Full Stack y optimización de procesos mediante el análisis de datos y la automatización con IA. Especialista en integrar tecnologías modernas como React y Node.js para generar eficiencia operativa.
        </p>
        
        <div class="flex flex-wrap gap-2 mt-2 opacity-0 animate-fade-in-up animate-delay-300">
          {skills.map((skill) => (
            <Badge variant="outline" class="bg-background/50 backdrop-blur-sm border-border/50 text-xs px-3 py-1 rounded-md hover:border-primary/50 transition-colors">
              {skill}
            </Badge>
          ))}
        </div>

        <div class="flex gap-4 mt-8 opacity-0 animate-fade-in-up animate-delay-400">
          <a href="#proyectos">
            <Button size="lg" class="rounded-full px-8 shadow-[0_0_20px_rgba(79,70,229,0.3)] hover:shadow-[0_0_30px_rgba(79,70,229,0.5)] transition-all">
              Ver Proyectos
            </Button>
          </a>
          <a href="#contacto">
            <Button variant="secondary" size="lg" class="rounded-full px-8 glass-panel hover:bg-secondary/80">
              Contactar
            </Button>
          </a>
        </div>
      </div>
      
      <div class="w-56 h-56 md:w-72 md:h-72 lg:w-96 lg:h-96 shrink-0 relative opacity-0 animate-fade-in-up animate-delay-300">
        <div class="absolute inset-0 bg-gradient-to-tr from-primary to-accent rounded-full blur-2xl opacity-20"></div>
        <Image src={profileImage} alt="Retrato de Carlos González" width={400} height={400} class="rounded-full object-cover w-full h-full border-4 border-background shadow-xl relative z-10" />
      </div>
    </section>

    <!-- Experiencia Section -->
    <section id="experiencia" class="py-16 md:py-24 relative opacity-0 animate-fade-in-up animate-delay-500">
      <div class="flex flex-col gap-3 mb-12">
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight">Experiencia Profesional</h2>
        <div class="h-1 w-20 bg-primary rounded-full"></div>
      </div>
      
      <div class="space-y-8 relative before:absolute before:inset-0 before:ml-5 before:-translate-x-px md:before:mx-auto md:before:translate-x-0 before:h-full before:w-0.5 before:bg-gradient-to-b before:from-transparent before:via-border before:to-transparent">
        {experience.map((job) => (
          <div class="relative flex items-center justify-between md:justify-normal md:odd:flex-row-reverse group is-active">
            <!-- Timeline dot -->
            <div class="flex items-center justify-center w-10 h-10 rounded-full border-4 border-background bg-primary shadow shrink-0 md:order-1 md:group-odd:-translate-x-1/2 md:group-even:translate-x-1/2 z-10 relative">
               <div class="w-2 h-2 bg-background rounded-full"></div>
            </div>
            
            <!-- Card -->
            <div class="w-[calc(100%-4rem)] md:w-[calc(50%-2.5rem)] glass-panel glass-panel-hover rounded-2xl p-6 md:p-8 relative">
              <p class="text-sm font-semibold text-primary mb-2 tracking-wider uppercase">{job.period}</p>
              <h3 class="text-xl font-bold font-heading">{job.role}</h3>
              <p class="text-lg text-muted-foreground mb-4">{job.company}</p>
              <p class="text-base text-foreground/80 leading-relaxed font-light">{job.description}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Educación Section -->
    <section id="educacion" class="py-16 md:py-24 opacity-0 animate-fade-in-up [animation-delay:600ms]">
      <div class="glass-panel rounded-3xl p-8 md:p-12 relative overflow-hidden">
        <!-- Decoration -->
        <div class="absolute top-0 right-0 w-64 h-64 bg-accent/10 rounded-full blur-[80px] -translate-y-1/2 translate-x-1/2 pointer-events-none"></div>
        
        <div class="flex flex-col gap-3 mb-10 relative z-10">
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight">Educación y Formación</h2>
          <div class="h-1 w-20 bg-accent rounded-full"></div>
        </div>
        
        <div class="space-y-10 relative z-10">
          {education.map((edu) => (
            <div class="flex flex-col md:flex-row gap-4 md:gap-8 border-l-2 border-primary/30 pl-6 relative">
              <div class="absolute w-3 h-3 bg-primary rounded-full -left-[7px] top-1.5 ring-4 ring-background"></div>
              <div class="md:w-1/4 pt-1">
                <p class="text-sm font-semibold text-muted-foreground">{edu.period}</p>
              </div>
              <div class="md:w-3/4">
                <h3 class="text-xl font-bold font-heading">{edu.degree}</h3>
                <p class="text-lg text-foreground/90 mb-3">{edu.institution}</p>
                <p class="text-base text-muted-foreground leading-relaxed font-light">{edu.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Proyectos Section -->
    <section id="proyectos" class="py-16 md:py-24 opacity-0 animate-fade-in-up [animation-delay:700ms]">
      <div class="flex flex-col gap-3 mb-12">
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight">Proyectos Destacados</h2>
        <div class="h-1 w-20 bg-primary rounded-full"></div>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {projects.map((project) => (
          <div class="glass-panel glass-panel-hover rounded-2xl flex flex-col h-full overflow-hidden group">
            {project.image && (
              <div class="w-full h-48 overflow-hidden">
                <Image src={project.image} alt={`Captura del proyecto ${project.title}`} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
              </div>
            )}
            <div class="p-6 md:p-8 flex flex-col h-full">
              <h3 class="text-2xl font-bold font-heading mb-3 group-hover:text-primary transition-colors">{project.title}</h3>
              <p class="text-muted-foreground font-light leading-relaxed mb-6 flex-grow">{project.description}</p>
              
              <div class="flex flex-col gap-5 mt-auto">
                <div class="flex flex-wrap gap-2">
                  {project.tags.map((tag) => (
                    <span class="text-xs font-medium px-2.5 py-1 rounded-md bg-secondary text-secondary-foreground border border-border/50">
                      {tag}
                    </span>
                  ))}
                </div>
                
                <div class="flex items-center gap-4 pt-1">
                  {project.repoUrl && (
                    <a href={project.repoUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-sm font-medium text-muted-foreground hover:text-foreground transition-colors">
                      <Github class="w-4 h-4" />
                      Código
                    </a>
                  )}
                  {project.demoUrl && (
                    <a href={project.demoUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-sm font-medium text-primary hover:text-primary/80 transition-colors">
                      <ExternalLink class="w-4 h-4" />
                      Visitar
                    </a>
                  )}
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Contacto Section -->
    <section id="contacto" class="py-16 md:py-32 max-w-3xl mx-auto text-center opacity-0 animate-fade-in-up [animation-delay:800ms]">
      <div class="glass-panel rounded-3xl p-8 md:p-14 relative overflow-hidden">
        <!-- Decoration -->
        <div class="absolute bottom-0 left-1/2 -translate-x-1/2 translate-y-1/2 w-full h-1/2 bg-primary/10 blur-[80px] pointer-events-none"></div>
        
        <div class="flex flex-col gap-4 mb-10 relative z-10">
          <h2 class="text-4xl md:text-5xl font-bold tracking-tight font-heading">¿Trabajamos juntos?</h2>
          <p class="text-muted-foreground text-lg md:text-xl font-light">
            Envíame un mensaje o escríbeme directamente a <br class="hidden md:inline" />
            <a href="mailto:sebigonza1701@gmail.com" class="font-medium text-primary hover:underline underline-offset-4">sebigonza1701@gmail.com</a>
          </p>
        </div>
        
        <form class="flex flex-col gap-5 text-left relative z-10 mt-8">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            <div class="space-y-2">
              <label for="name" class="text-sm font-medium ml-1">Nombre</label>
              <Input id="name" placeholder="Tu nombre" required class="bg-background/50 border-border/50 focus-visible:ring-primary h-12 rounded-xl" />
            </div>
            <div class="space-y-2">
              <label for="email" class="text-sm font-medium ml-1">Email</label>
              <Input id="email" type="email" placeholder="tu@email.com" required class="bg-background/50 border-border/50 focus-visible:ring-primary h-12 rounded-xl" />
            </div>
          </div>
          <div class="space-y-2">
            <label for="message" class="text-sm font-medium ml-1">Mensaje</label>
            <Textarea id="message" placeholder="¿En qué te puedo ayudar?" rows={5} required class="bg-background/50 border-border/50 focus-visible:ring-primary resize-none rounded-xl p-4" />
          </div>
          <Button size="lg" class="w-full sm:w-auto sm:self-center mt-6 rounded-full px-12 h-14 text-base font-semibold shadow-[0_0_20px_rgba(79,70,229,0.2)] hover:shadow-[0_0_30px_rgba(79,70,229,0.4)] transition-all">
            Enviar Mensaje
          </Button>
        </form>
      </div>
    </section>
  </main>

  <footer class="border-t border-border/40 py-8 md:py-12 mt-12 bg-background/40 backdrop-blur-md">
    <div class="container mx-auto max-w-5xl px-4 lg:px-8 flex flex-col items-center justify-between gap-6 md:flex-row">
      <div class="flex items-center gap-2">
        <span class="font-heading font-bold text-lg">CG.</span>
        <span class="text-muted-foreground text-sm">© 2026 Todos los derechos reservados.</span>
      </div>
      
      <p class="text-sm text-center text-muted-foreground md:text-left font-light">
        Construido con <a href="https://astro.build" target="_blank" rel="noreferrer" class="font-medium text-foreground hover:text-primary transition-colors">Astro</a> y Tailwind CSS.
      </p>
      
      <div class="flex items-center gap-6">
        <a href="mailto:sebigonza1701@gmail.com" class="text-muted-foreground hover:text-primary transition-colors text-sm font-medium">Email</a>
        <a href="#" class="text-muted-foreground hover:text-primary transition-colors text-sm font-medium">LinkedIn</a>
        <a href="#" class="text-muted-foreground hover:text-primary transition-colors text-sm font-medium">GitHub</a>
      </div>
    </div>
  </footer>
</Layout>
